#########################################
# Haland PetCare - .gitignore
# Comprehensive gitignore for Laravel + Railway
#########################################

# -----------------------------------------
# Dependencies
# -----------------------------------------
/vendor/
node_modules/
bower_components/
package-components.json

# -----------------------------------------
# Environment & Configuration
# -----------------------------------------
.env
.env.*
!.env.example
!.env.example.backup
!.env.production.example

# -----------------------------------------
# Laravel Framework
# -----------------------------------------
# Storage (keep structure, ignore contents)
/storage/*.key
/storage/pail*
/storage/logs/*
!/storage/logs/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/public/storage

# Bootstrap cache
/bootstrap/cache/*.php
!bootstrap/cache/.gitignore

# -----------------------------------------
# Frontend Build Assets
# -----------------------------------------
/public/build/
/public/hot
/public/mix-manifest.json
/public/fonts-manifest.dev.json
/public/js/
/public/css/

# -----------------------------------------
# Testing & Coverage
# -----------------------------------------
/tests/coverage/
/coverage/
.phpunit.result.cache
.phpunit.cache/
phpunit.xml.bak
phpunit.xml.backup
.phpunit.serialised
.phpunit.cache.result
.phpunit.cache.version
.phpunit.cache.methods
.phpunit.cache.phpunit
.phpunit.cache.data

# -----------------------------------------
# IDE & Editor Files
# -----------------------------------------
# JetBrains
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
.vscode-server/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn
*~
tags
tags.lock
Session.vim

# Emacs
\#*\#
.#*
*.elc

# NetBeans
/nbproject/
/nbbuild/
/nbdist/
/nbactions/
nb-configuration.xml

# Vim
*.swp
*.swo
*~

# -----------------------------------------
# OS Files
# -----------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
ehthumbs.db
Thumbs.db
desktop.ini

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# -----------------------------------------
# PHP & Composer
# -----------------------------------------
.phpactor.json
.php-cs-fixer.cache
.php_cs.cache
.php_cs.dist.cache
phpcs.xml
phpcs.xml.dist
phpstan.neon
phpstan.neon.dist
psalm.xml
psalm.xml.dist
_includes/
_helpers.php

# -----------------------------------------
# Node & NPM
# -----------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock
package-lock.json
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# -----------------------------------------
# Yarn
# -----------------------------------------
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------
# Docker
# -----------------------------------------
docker-compose.override.yml
docker-compose.override.yaml
.docker/
*.dockerignore

# -----------------------------------------
# Railway
# -----------------------------------------
.railway/
railway.json
railway.toml
railway*.json
railway*.toml

# -----------------------------------------
# Vercel
# -----------------------------------------
.vercel/
.vercelignore

# -----------------------------------------
# Netlify
# -----------------------------------------
.netlify/
.netlifyignore

# -----------------------------------------
# Backup & Archive Files
# -----------------------------------------
*.bak
*.backup
*.old
*.orig
*.save
*.sql
*.sql.gz
*.sql.bz2
*.sql.xz
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.rar
*.7z

# -----------------------------------------
# Temporary & Cache Files
# -----------------------------------------
/tmp/
.cache/
*.tmp
*.temp
*.cache
*.log
*.log.*
logs/
log/

# -----------------------------------------
# Runtime & Session Files
# -----------------------------------------
/runtime/
*.pid
*.seed
*.pid.lock

# -----------------------------------------
# Security & Secrets
# -----------------------------------------
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks
*.keystore
secrets/
credentials/
*.credentials
*.secret

# -----------------------------------------
# Misc
# -----------------------------------------
*.md.bak
*.txt.bak
*.html.bak
*.css.bak
*.js.bak
*.php.bak

# -----------------------------------------
# Debug & Profiling
# -----------------------------------------
xdebug.log
cachegrind.out*
callgrind.out*
profiler.*
*.prof

# -----------------------------------------
# Misc Laravel
# -----------------------------------------
composer.phar
artisan.phar
/storage/*.key
storage/*.key
Homestead.json
Homestead.yaml
Vagrantfile
.env.dusk.*
.env.dusk.local

# -----------------------------------------
# Telescope (if installed)
# -----------------------------------------
/storage/telescope/

# -----------------------------------------
# Pennant (if installed)
# -----------------------------------------
/storage/pennant/

# -----------------------------------------
# IDE Specific
# -----------------------------------------
# PhpStorm
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries
.idea/shelf

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.vscode/*.code-workspace

# -----------------------------------------
# Tailwind CSS (if using JIT)
# -----------------------------------------
/public/css/*.css
/public/js/*.js

# -----------------------------------------
# Compiled Files
# -----------------------------------------
*.min.js
*.min.css
*.map

# -----------------------------------------
# Misc
# -----------------------------------------
*.pyc
*.pyo
*.pyd
*.so
*.dylib
*.dll
*.exe
*.o
*.a
*.la
*.lo

# -----------------------------------------
# Keep these files
# -----------------------------------------
!.gitignore
!README.md
!.env.example
!phpunit.xml
!phpunit.xml.dist
!composer.json
!package.json
!vite.config.js
!tailwind.config.js
!postcss.config.js
!server.php
!deploy.sh
!Procfile
!nixpacks.toml
!Dockerfile
!docker-compose.yml
